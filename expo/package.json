{
  "name": "medina",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web --port 8082",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "export:web": "expo export --platform web --output-dir ../static/app",
    "build": "EAS_NO_VCS=1 npx --yes eas-cli@latest build --platform android --profile internal",
    "update:internal": "EAS_NO_VCS=1 npx --yes eas-cli@latest update --channel internal --auto",
    "build:android:internal": "EAS_NO_VCS=1 npx --yes eas-cli@latest build --platform android --profile internal"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@react-native-vector-icons/feather": "^13.1.2",
    "expo": "~56.0.12",
    "expo-asset": "~56.0.17",
    "expo-audio": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-linking": "~56.0.14",
    "expo-network": "~56.0.5",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.19",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.0",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
